{
  "name": "@devalok/shilp-sutra",
  "version": "0.1.0",
  "description": "Devalok Design System — tokens, components, and patterns for Next.js",
  "type": "module",
  "sideEffects": [
    "**/*.css"
  ],
  "exports": {
    "./tokens": "./dist/tokens/index.css",
    "./ui": {
      "import": "./dist/ui/index.js",
      "types": "./dist/ui/index.d.ts"
    },
    "./composed": {
      "import": "./dist/composed/index.js",
      "types": "./dist/composed/index.d.ts"
    },
    "./shared": {
      "import": "./dist/composed/index.js",
      "types": "./dist/composed/index.d.ts"
    },
    "./layout": {
      "import": "./dist/layout/index.js",
      "types": "./dist/layout/index.d.ts"
    },
    "./karm": {
      "import": "./dist/karm/index.js",
      "types": "./dist/karm/index.d.ts"
    },
    "./karm/board": {
      "import": "./dist/karm/board/index.js",
      "types": "./dist/karm/board/index.d.ts"
    },
    "./karm/tasks": {
      "import": "./dist/karm/tasks/index.js",
      "types": "./dist/karm/tasks/index.d.ts"
    },
    "./karm/chat": {
      "import": "./dist/karm/chat/index.js",
      "types": "./dist/karm/chat/index.d.ts"
    },
    "./karm/dashboard": {
      "import": "./dist/karm/dashboard/index.js",
      "types": "./dist/karm/dashboard/index.d.ts"
    },
    "./karm/client": {
      "import": "./dist/karm/client/index.js",
      "types": "./dist/karm/client/index.d.ts"
    },
    "./karm/admin": {
      "import": "./dist/karm/admin/index.js",
      "types": "./dist/karm/admin/index.d.ts"
    },
    "./karm/custom-buttons": {
      "import": "./dist/karm/custom-buttons/index.js",
      "types": "./dist/karm/custom-buttons/index.d.ts"
    },
    "./tailwind": {
      "import": "./dist/tailwind/index.js",
      "types": "./dist/tailwind/index.d.ts"
    },
    "./fonts/*": "./fonts/*"
  },
  "files": [
    "dist",
    "fonts",
    "README.md"
  ],
  "scripts": {
    "dev": "storybook dev -p 6006",
    "build": "vite build && pnpm build:tokens",
    "build:tokens": "node scripts/copy-tokens.mjs",
    "build-storybook": "storybook build",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src/",
    "lint:fix": "eslint src/ --fix",
    "format": "prettier --write \"src/**/*.{ts,tsx,css}\"",
    "format:check": "prettier --check \"src/**/*.{ts,tsx,css}\"",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepublishOnly": "pnpm build"
  },
  "peerDependencies": {
    "next": ">=14",
    "react": "^18 || ^19",
    "react-dom": "^18 || ^19"
  },
  "peerDependenciesMeta": {
    "next": {
      "optional": true
    }
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@floating-ui/react-dom": "^2.1.7",
    "@tabler/icons-react": "^3.37.1",
    "@tanstack/react-table": "^8.21.2",
    "@tanstack/react-virtual": "^3.13.19",
    "@tiptap/extension-placeholder": "^2.11.5",
    "@tiptap/react": "^2.11.5",
    "@tiptap/starter-kit": "^2.11.5",
    "aria-hidden": "^1.2.4",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "d3-array": "^3.2.4",
    "d3-axis": "^3.0.0",
    "d3-format": "^3.1.2",
    "d3-interpolate": "^3.0.1",
    "d3-scale": "^4.0.2",
    "d3-selection": "^3.0.0",
    "d3-shape": "^3.2.0",
    "d3-time-format": "^4.1.0",
    "d3-transition": "^3.0.1",
    "date-fns": "^4.1.0",
    "input-otp": "^1.4.2",
    "react-markdown": "^10.1.0",
    "react-remove-scroll": "^2.6.3",
    "tailwind-merge": "^3.0.1"
  },
  "devDependencies": {
    "@storybook/addon-a11y": "^8.6.0",
    "@storybook/addon-docs": "^8.6.14",
    "@storybook/addon-essentials": "^8.6.0",
    "@storybook/react": "^8.6.0",
    "@storybook/react-vite": "^8.6.0",
    "@storybook/test": "^8.6.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/d3-array": "^3.2.2",
    "@types/d3-axis": "^3.0.6",
    "@types/d3-format": "^3.0.4",
    "@types/d3-interpolate": "^3.0.4",
    "@types/d3-scale": "^4.0.9",
    "@types/d3-selection": "^3.0.11",
    "@types/d3-shape": "^3.1.8",
    "@types/d3-time-format": "^4.0.3",
    "@types/d3-transition": "^3.0.9",
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "@typescript-eslint/eslint-plugin": "^8.56.1",
    "@typescript-eslint/parser": "^8.56.1",
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.4.20",
    "eslint": "^9.19.0",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-react-hooks": "^7.0.1",
    "globals": "^17.3.0",
    "jsdom": "^28.1.0",
    "postcss": "^8.5.1",
    "prettier": "^3.4.2",
    "remark-gfm": "^4.0.1",
    "storybook": "^8.6.0",
    "storybook-dark-mode": "^4.0.2",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.56.1",
    "vite": "^5.4.11",
    "vite-plugin-dts": "^4.5.0",
    "vitest": "^4.0.18",
    "vitest-axe": "^0.1.0"
  },
  "packageManager": "pnpm@10.0.0",
  "engines": {
    "node": ">=20.0.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/devalok-design/shilp-sutra.git"
  },
  "license": "UNLICENSED",
  "private": false
}
