{
  "name": "@devalok/shilp-sutra-brand",
  "version": "0.4.1",
  "description": "Brand logos and SVG assets for the Devalok Design System",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "sideEffects": [
    "**/*.css"
  ],
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./devalok": {
      "import": "./dist/devalok/index.js",
      "types": "./dist/devalok/index.d.ts"
    },
    "./karm": {
      "import": "./dist/karm/index.js",
      "types": "./dist/karm/index.d.ts"
    },
    "./assets/*": "./dist/assets/*"
  },
  "files": [
    "dist",
    "README.md",
    "llms.txt"
  ],
  "scripts": {
    "build": "vite build && node scripts/copy-assets.mjs",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src/",
    "prepublishOnly": "pnpm build"
  },
  "peerDependencies": {
    "react": "^18 || ^19",
    "react-dom": "^18 || ^19"
  },
  "dependencies": {
    "clsx": "^2.1.1",
    "tailwind-merge": "^3.0.1"
  }
}
