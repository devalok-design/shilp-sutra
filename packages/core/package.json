{
  "name": "@devalok/shilp-sutra",
  "version": "0.1.0",
  "description": "Devalok Design System — tokens, components, and patterns for Next.js",
  "license": "MIT",
  "type": "module",
  "sideEffects": [
    "**/*.css"
  ],
  "exports": {
    "./tokens": "./dist/tokens/index.css",
    "./ui": {
      "import": "./dist/ui/index.js",
      "types": "./dist/ui/index.d.ts"
    },
    "./composed": {
      "import": "./dist/composed/index.js",
      "types": "./dist/composed/index.d.ts"
    },
    "./shell": {
      "import": "./dist/shell/index.js",
      "types": "./dist/shell/index.d.ts"
    },
    "./hooks": {
      "import": "./dist/hooks/index.js",
      "types": "./dist/hooks/index.d.ts"
    },
    "./tailwind": {
      "import": "./dist/tailwind/index.js",
      "types": "./dist/tailwind/index.d.ts"
    },
    "./fonts/*": "./fonts/*"
  },
  "files": [
    "dist",
    "fonts",
    "README.md"
  ],
  "scripts": {
    "build": "vite build && pnpm build:tokens",
    "build:tokens": "node scripts/copy-tokens.mjs",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src/",
    "test": "vitest run",
    "prepublishOnly": "pnpm build"
  },
  "peerDependencies": {
    "next": ">=14",
    "react": "^18 || ^19",
    "react-dom": "^18 || ^19"
  },
  "peerDependenciesMeta": {
    "next": {
      "optional": true
    }
  },
  "dependencies": {
    "@floating-ui/react-dom": "^2.1.7",
    "@tabler/icons-react": "^3.37.1",
    "@tanstack/react-table": "^8.21.2",
    "@tanstack/react-virtual": "^3.13.19",
    "@tiptap/extension-placeholder": "^2.11.5",
    "@tiptap/react": "^2.11.5",
    "@tiptap/starter-kit": "^2.11.5",
    "aria-hidden": "^1.2.4",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "d3-array": "^3.2.4",
    "d3-axis": "^3.0.0",
    "d3-format": "^3.1.2",
    "d3-interpolate": "^3.0.1",
    "d3-scale": "^4.0.2",
    "d3-selection": "^3.0.0",
    "d3-shape": "^3.2.0",
    "d3-time-format": "^4.1.0",
    "d3-transition": "^3.0.1",
    "date-fns": "^4.1.0",
    "input-otp": "^1.4.2",
    "react-markdown": "^10.1.0",
    "react-remove-scroll": "^2.6.3",
    "tailwind-merge": "^3.0.1"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "packageManager": "pnpm@10.0.0"
}
